# --- Database -----------------------------------------------------------
# Matches docker-compose.yml. Override host/port if running PG elsewhere.
DATABASE_URL="postgresql://wortschatz:wortschatz_dev@localhost:5432/wortschatz?schema=public"

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"
# Trusted base URL for callbacks (NextAuth v5 requires this in production)
AUTH_URL="http://localhost:3000"

# Google OAuth credentials. Create at https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Anthropic Claude API ----------------------------------------------
# Required for AI exercise generation, evaluation and text review.
# Without this, AI features stay disabled and only stub responses are returned.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- App ---------------------------------------------------------------
# Comma-separated locale list for next-intl.
NEXT_PUBLIC_DEFAULT_LOCALE="en"
