# --- Database -----------------------------------------------------------
# Matches docker-compose.yml. Override host/port if running PG elsewhere.
DATABASE_URL="postgresql://wortschatz:wortschatz_dev@localhost:5432/wortschatz?schema=public"

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"
# Trusted base URL for callbacks (NextAuth v5 requires this in production)
AUTH_URL="http://localhost:3000"

# Google OAuth credentials. Create at https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Anthropic Claude API ----------------------------------------------
# Required for AI exercise generation, evaluation and text review.
# Without this key, `src/lib/ai.ts` returns deterministic stubs and
# writes nothing to the DB (no cache, no rate-limit, no usage row).
#
# When the key is set, every call is gated by:
#   - a response cache (`AiCache`, SHA-256 keyed) with per-endpoint TTL —
#     EVALUATE_ANSWER: 1h, GENERATE_EXERCISE: 30d, REVIEW_TEXT: never;
#   - a rolling 24h per-user rate limit (`AiRateLimit`) —
#     REVIEW_TEXT 20/day, EVALUATE_ANSWER 200/day, GENERATE_EXERCISE 50/day;
#   - a usage log row (`AiUsage`) with `cacheHit` + integer-microcents cost.
# Tunables live in `src/config/limits.ts`.
ANTHROPIC_API_KEY=""
# Override the model used for all three endpoints. Pricing lives in
# `AI_MODEL_PRICING_MICROCENTS_PER_TOKEN` — add an entry there for any
# new model id or the cost estimate falls back to 0.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- App ---------------------------------------------------------------
# Comma-separated locale list for next-intl.
NEXT_PUBLIC_DEFAULT_LOCALE="en"
