# --- Database -----------------------------------------------------------
# Matches docker-compose.dev.yml (local dev Postgres). Override host/port if running PG elsewhere.
DATABASE_URL="postgresql://wortschatz:wortschatz_dev@localhost:5432/wortschatz?schema=public"

# --- NextAuth -----------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"
# Trusted base URL for callbacks (NextAuth v5 requires this in production)
AUTH_URL="http://localhost:3000"

# Google OAuth credentials. Create at https://console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Anthropic Claude API ----------------------------------------------
# Only used directly by the admin script
# `scripts/generate-exercises.ts`. All user-facing Claude calls
# (reviewText, evaluateAnswer) go through apps/api via the API_URL
# below, so the api process owns its own copy of this key.
#
# When the key is set on apps/api, every call is gated by:
#   - a response cache (`AiCache`, SHA-256 keyed) with per-endpoint TTL —
#     EVALUATE_ANSWER: 1h, GENERATE_EXERCISE: 30d, REVIEW_TEXT: never;
#   - a rolling 24h per-user rate limit (`AiRateLimit`) —
#     REVIEW_TEXT 20/day, EVALUATE_ANSWER 200/day, GENERATE_EXERCISE 50/day;
#   - a usage log row (`AiUsage`) with `cacheHit` + integer-microcents cost.
# Tunables live in @wortschatz/config.
ANTHROPIC_API_KEY=""
# Override the model used for admin exercise generation. Pricing lives
# in AI_MODEL_PRICING_MICROCENTS_PER_TOKEN — add an entry there for
# any new model id or the cost estimate falls back to 0.
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Observability (Helicone) ------------------------------------------
# Optional. When set, every Anthropic/OpenAI call routes through the
# helicone.ai proxy for prompt/response/cost logging. Leave unset to call
# the providers directly (today's behavior). Create a free key at
# https://helicone.ai. See apps/web/scripts/README.md for details.
# HELICONE_API_KEY=  # optional, enables LLM call logging via helicone.ai

# --- Internal API (apps/api) -------------------------------------------
# Where apps/web reaches apps/api. In dev both run on localhost; in
# prod this would point at the VPS hosting apps/api.
API_URL="http://localhost:4000"

# Shared secret used to authenticate every web → api call. Must equal
# the value in apps/api/.env. The web also sends the acting user's id
# as X-User-Id (resolved server-side from the NextAuth session before
# the call leaves the web server).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=""

# --- App ---------------------------------------------------------------
# Comma-separated locale list for next-intl.
NEXT_PUBLIC_DEFAULT_LOCALE="en"

# --- Avatar storage ----------------------------------------------------
# Avatars currently always write to `public/uploads/avatars/` (no config
# needed). The local filesystem doesn't survive Vercel/Netlify ephemeral
# deploys — swap to Vercel Blob or S3 before going to prod. When that
# lands, this var will pick the driver. Uncomment after wiring it up:
# STORAGE_DRIVER="local"   # one of: local | vercel-blob | s3
