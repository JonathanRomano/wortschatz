# --- API process -------------------------------------------------------
NODE_ENV=development
PORT=4000

# --- Database (shared with apps/web) ------------------------------------
DATABASE_URL="postgresql://wortschatz:wortschatz_dev@localhost:5432/wortschatz?schema=public"

# --- Anthropic ----------------------------------------------------------
# Without a key the AI routes return deterministic stubs and write
# nothing to the cache / usage / rate-limit tables.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- OpenAI (optional) --------------------------------------------------
# Enables GPT as a provider for POST /ai/generate-exercise (provider="gpt").
# Without it, gpt requests return a deterministic stub; Claude is the default.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# --- Observability (Helicone) ------------------------------------------
# Optional. When set, the api's Claude calls route through the helicone.ai
# proxy for prompt/response/cost logging. Leave unset to call Anthropic
# directly. Free key at https://helicone.ai.
# HELICONE_API_KEY=  # optional, enables LLM call logging via helicone.ai

# --- Internal auth ------------------------------------------------------
# Shared with apps/web's INTERNAL_API_SECRET. The web sends this on every
# request as `X-Internal-Secret`, plus `X-User-Id` carrying the
# authenticated user's id (resolved server-side from the NextAuth session
# before the request leaves the web app).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=""

# --- CORS ---------------------------------------------------------------
WEB_URL="http://localhost:3000"
