# --- API process -------------------------------------------------------
NODE_ENV=development
PORT=4000

# --- Database (shared with apps/web) ------------------------------------
DATABASE_URL="postgresql://wortschatz:wortschatz_dev@localhost:5432/wortschatz?schema=public"

# --- Anthropic ----------------------------------------------------------
# Without a key the AI routes return deterministic stubs and write
# nothing to the cache / usage / rate-limit tables.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Internal auth ------------------------------------------------------
# Shared with apps/web's INTERNAL_API_SECRET. The web sends this on every
# request as `X-Internal-Secret`, plus `X-User-Id` carrying the
# authenticated user's id (resolved server-side from the NextAuth session
# before the request leaves the web app).
# Generate with: openssl rand -base64 32
INTERNAL_API_SECRET=""

# --- CORS ---------------------------------------------------------------
WEB_URL="http://localhost:3000"
