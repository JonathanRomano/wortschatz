# Make pnpm hoist transitive deps to the root node_modules, mirroring npm's
# behavior. Avoids breaking Next.js / MUI / emotion peer-dep assumptions during
# the Sprint 03 monorepo migration. Tighten once the apps/web split (Task 5)
# lands and we've audited each package's direct deps.
shamefully-hoist=true

# Allow build scripts (sharp, bcryptjs native compile, prisma) to run.
enable-pre-post-scripts=true
