# ============================================================================
# Wortschatz API — production env (Hetzner VPS / Docker Compose)
# ----------------------------------------------------------------------------
# On the server, copy this file to `.env` (gitignored) in the repo root and
# fill in real values:
#
#     cp .env.production.example .env && nano .env
#     docker compose up -d --build
#
# docker-compose.yml reads these. Postgres and the API both run in Compose;
# the web app stays on Vercel and reaches this API over the public PORT.
# ============================================================================

# --- Postgres (runs inside Compose) — REQUIRED ------------------------------
POSTGRES_USER=wortschatz
POSTGRES_PASSWORD=                 # REQUIRED — set a strong password
POSTGRES_DB=wortschatz
# NOTE: DATABASE_URL is composed automatically in docker-compose.yml from the
# three POSTGRES_* values above (the DB host is the `postgres` service). You do
# NOT set DATABASE_URL here.

# --- Web <-> API auth — REQUIRED --------------------------------------------
# Must match INTERNAL_API_SECRET in the Vercel (apps/web) env EXACTLY, and be
# at least 32 characters. Generate with:  openssl rand -base64 32
INTERNAL_API_SECRET=

# Public URL of the web app (Vercel) — used for CORS on the API. REQUIRED.
WEB_URL=https://your-app.vercel.app

# --- Anthropic (Claude) — REQUIRED for real AI ------------------------------
# Without a key, the AI routes return deterministic stubs (no errors).
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6 in code):
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (GPT generation) — OPTIONAL -------------------------------------
# Enables provider="gpt" on POST /ai/generate-exercise; stubs without it.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Helicone (LLM observability) — OPTIONAL --------------------------------
# When set, every provider call routes through helicone.ai for logging.
HELICONE_API_KEY=

# --- Runtime — set by docker-compose.yml; no need to define here ------------
# NODE_ENV=production
# PORT=4000
