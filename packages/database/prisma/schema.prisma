// Wortschatz - Prisma schema
//
// Run `npm run db:push` after editing for fast local iteration, or
// `npm run db:migrate -- --name <change>` to generate a migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums --------------------------------------------------------------

enum UserRole {
  USER
  TEACHER
  ADMIN
}

enum UiLanguage {
  PT
  EN
  TR
  UK
}

enum CefrLevel {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum ExerciseType {
  FILL_IN_THE_BLANK
  MULTIPLE_CHOICE
  TRANSLATION
  WORD_ORDER
  MATCHING
  LISTENING_COMPREHENSION
  READING_COMPREHENSION
  VERB_CONJUGATION
  ERROR_CORRECTION
  FREE_WRITING
}

enum ExerciseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MuenzenReason {
  EXERCISE_COMPLETE
  PERFECT_SCORE_BONUS
  DAILY_STREAK
  SPENT_AI_REVIEW
  ADMIN_ADJUSTMENT
  BONUS
}

// --- App models ---------------------------------------------------------

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  name              String?
  image             String?
  // bcrypt hash. Null when the account was created via OAuth only.
  password          String?
  role              UserRole      @default(USER)
  preferredLanguage UiLanguage    @default(EN)

  // The "ü" in "Münzen" is preserved on the web side; the column itself
  // uses an ASCII name so DB tooling stays portable.
  muenzen           Int           @default(0)
  streak            Int           @default(0)
  lastActiveAt      DateTime?

  // Sprint 02 Task 6 — profile fields. `bio` is capped to 280 chars in
  // the save action; `nativeLanguage` is an ISO 639-1 code (free-form
  // here so future locales don't require a migration); `learningLevel`
  // and `dailyGoal` drive the dashboard ring and the AI review prompt.
  bio               String?
  nativeLanguage    String?
  learningLevel     CefrLevel?
  dailyGoal         Int           @default(5)
  avatarUrl         String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  accounts          Account[]
  sessions          Session[]
  authoredExercises Exercise[]    @relation("ExerciseAuthor")
  attempts          UserExercise[]
  transactions      MuenzenTransaction[]
  reviewRequests    AIReviewRequest[]
  preferences       UserPreference[]
  comments          ExerciseComment[]
  commentLikes      CommentLike[]
}

// Sprint 02 Task 8 — per-exercise-type user preferences. Currently used
// for the "don't show the intro again" toggle on the type runner. The
// row's existence alone is the signal — `skipIntro` is a placeholder
// for future bools to live on this same row.
model UserPreference {
  id          String       @id @default(cuid())
  userId      String
  key         ExerciseType
  skipIntro   Boolean      @default(true)
  createdAt   DateTime     @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model Exercise {
  id             String         @id @default(cuid())
  type           ExerciseType
  title          String
  // Per-locale strings: { en, pt, tr, uk }. Read with pickLocalized()
  // from src/lib/exercises/i18n.ts so missing locales fall back to en.
  instructions   Json
  // ISO 639-1, defaulting to German. Kept on the row in case future
  // exercises target other languages.
  targetLanguage String         @default("de")
  level          CefrLevel
  // Type-specific payload. See src/lib/exercises/schemas.ts for the
  // discriminated union of acceptable shapes.
  content        Json
  solution       Json
  // Per-locale strings — same shape as `instructions`.
  explanation    Json
  tags           String[]       @default([])
  status         ExerciseStatus @default(DRAFT)
  // AI model that generated this exercise (e.g. "claude-sonnet-4-6").
  // Nullable: rows created before this column, or authored manually
  // without an AI call, leave it NULL.
  model          String?

  authorId       String?
  author         User?          @relation("ExerciseAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  attempts       UserExercise[]
  comments       ExerciseComment[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([type, level, status])
  @@index([status])
}

// Sprint 02 Task 7 — per-exercise discussion thread. Soft-deleted rows
// stay in place so reply chains keep their context; the API hides
// `content` and the author for deleted rows. Word filter + per-minute
// rate limit are enforced at write time (see src/config/moderation.ts
// and the POST handler in src/app/api/exercises/[id]/comments/route.ts).
model ExerciseComment {
  id          String   @id @default(cuid())
  exerciseId  String
  userId      String
  // Trimmed; max 500 chars enforced at write time.
  content     String
  createdAt   DateTime @default(now())
  editedAt    DateTime?
  // Soft-delete; the row stays, content/author hidden in API responses.
  deletedAt   DateTime?

  exercise    Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes       CommentLike[]

  @@index([exerciseId, createdAt])
  @@index([userId])
}

model CommentLike {
  id         String          @id @default(cuid())
  commentId  String
  userId     String
  createdAt  DateTime        @default(now())

  comment    ExerciseComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
}

model UserExercise {
  id          String   @id @default(cuid())
  userId      String
  exerciseId  String
  // Whatever the user submitted, in the shape the renderer produced.
  answer      Json
  // 0-100. AI- or rule-evaluated.
  score       Int
  feedback    String
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([exerciseId])
}

model MuenzenTransaction {
  id        String        @id @default(cuid())
  userId    String
  // Positive = earned, negative = spent.
  amount    Int
  reason    MuenzenReason
  // Free-form context, e.g. exerciseId or aiReviewRequestId.
  refId     String?
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AIReviewRequest {
  id          String   @id @default(cuid())
  userId      String
  inputText   String
  feedback    String
  muenzenCost Int
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// --- AI infrastructure --------------------------------------------------
//
// Persisted cache, per-user rate-limit windows, and per-call usage log for
// the Claude integration in src/lib/ai.ts. See src/config/limits.ts for the
// TTLs and rate ceilings.

model AiCache {
  id           String   @id @default(cuid())
  // SHA-256 hex of the canonical prompt + endpoint + model. Indexed.
  key          String   @unique
  endpoint     String
  model        String
  // The cached response as JSON. Shape varies by endpoint.
  response     Json
  // Cumulative token usage from the original call.
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([expiresAt])
  @@index([endpoint])
}

model AiRateLimit {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String
  count       Int      @default(0)
  // Start of the rolling 24h window. Reset when now - windowStart > 1 day.
  windowStart DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([windowStart])
}

model AiUsage {
  id             String   @id @default(cuid())
  userId         String?  // null for system/admin scripts
  endpoint       String
  model          String
  inputTokens    Int
  outputTokens   Int
  // Estimated USD cost, computed from a per-model price table.
  // Stored as integer microcents (cost * 100000) to avoid float drift.
  costMicrocents Int
  cacheHit       Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
}

// --- NextAuth tables ----------------------------------------------------
// Standard schema from @auth/prisma-adapter.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
